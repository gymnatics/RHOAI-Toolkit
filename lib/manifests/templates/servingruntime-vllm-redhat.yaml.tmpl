# Red Hat vLLM (RHAIIS) ServingRuntime for RHOAI Dashboard
# This is the officially supported Red Hat image for vLLM inference.
# Usage: export NAME=vllm-rhaiis VERSION=3.2.5 && envsubst < servingruntime-vllm-redhat.yaml.tmpl | oc apply -f -
#
# Variables:
#   NAME       - Runtime name (e.g., vllm-rhaiis)
#   VERSION    - RHAIIS image tag (e.g., 3.3)
#   DISPLAY    - Display name in RHOAI dashboard
#   SHM_SIZE   - Shared memory size (default: 2Gi)
#
apiVersion: serving.kserve.io/v1alpha1
kind: ServingRuntime
metadata:
  name: ${NAME}
  annotations:
    opendatahub.io/apiProtocol: REST
    opendatahub.io/serving-runtime-scope: global
    opendatahub.io/recommended-accelerators: '["nvidia.com/gpu"]'
    opendatahub.io/template-display-name: "${DISPLAY}"
    opendatahub.io/template-name: rhaiis-cuda-runtime
    openshift.io/display-name: "${DISPLAY}"
  labels:
    opendatahub.io/dashboard: "true"
spec:
  annotations:
    prometheus.io/path: /metrics
    prometheus.io/port: "8080"
  containers:
    - name: kserve-container
      image: registry.redhat.io/rhaiis/vllm-cuda-rhel9:${VERSION}
      command:
        - python
        - -m
        - vllm.entrypoints.openai.api_server
      args:
        - '--port=8080'
        - '--model=/mnt/models'
        - '--served-model-name={{.Name}}'
      env:
        - name: HF_HOME
          value: /tmp/hf_home
      ports:
        - containerPort: 8080
          protocol: TCP
      volumeMounts:
        - name: shm
          mountPath: /dev/shm
  multiModel: false
  supportedModelFormats:
    - autoSelect: true
      name: vLLM
  volumes:
    - name: shm
      emptyDir:
        medium: Memory
        sizeLimit: ${SHM_SIZE}
