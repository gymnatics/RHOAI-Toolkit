# ML Model Endpoint (sklearn/xgboost classifier)
SKLEARN_API_URL=https://microloan-sklearn-financial-loan-demo.apps.<cluster>/v2/models/microloan-sklearn/infer

# LLM Endpoint (OpenAI-compatible chat completions)
LLM_API_URL=https://inference-gateway.apps.<cluster>/v1/chat/completions

# LLM model name sent in the request payload (must match deployed model name)
LLM_MODEL_NAME=qwen3-4b

# Optional: Bearer tokens for authenticated InferenceService endpoints
# Leave empty if token auth is not enabled on the model
#SKLEARN_API_TOKEN=
#LLM_API_TOKEN=

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here
SESSION_FILE_DIR=/tmp/flask_session

# Server Configuration
HOST=0.0.0.0
PORT=5000
